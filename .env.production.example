# FlipForm — Production Environment Example
# Do not commit real secrets.

# Public URLs
NEXT_PUBLIC_MARKETING_URL=https://flipform.com.br
NEXT_PUBLIC_APP_URL=https://app.flipform.com.br
NEXT_PUBLIC_ADMIN_URL=https://admin.flipform.com.br

# Host routing
APP_HOSTNAME=app.flipform.com.br
ADMIN_HOSTNAME=admin.flipform.com.br

# Database
DATABASE_URL=

# Auth
JWT_SECRET_CURRENT=
JWT_SECRET_PREVIOUS=

# Asaas production
ASAAS_BASE_URL=https://api.asaas.com/v3
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=

# Transactional email
EMAIL_PROVIDER=smtp
EMAIL_FROM=atendimento@flipform.com.br
EMAIL_REPLY_TO=atendimento@flipform.com.br

# SMTP
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=true

# Resend, optional alternative to SMTP
RESEND_API_KEY=

# Internal jobs
CRON_SECRET=
INTERNAL_JOB_SECRET=

# Observability
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Production guard
ALLOW_EMAIL_PROVIDER_NONE_IN_PRODUCTION=false
ALLOW_SANDBOX_ASAAS_IN_PRODUCTION=false
