# FlipForm — Local/Development Environment Example

# Public URLs
NEXT_PUBLIC_MARKETING_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3000/admin

# Host routing
APP_HOSTNAME=localhost
ADMIN_HOSTNAME=localhost

# Database
DATABASE_URL=

# Auth
JWT_SECRET_CURRENT=staging-local-secret
JWT_SECRET_PREVIOUS=

# Asaas sandbox/local
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_API_KEY=test-placeholder
ASAAS_WEBHOOK_TOKEN=test-placeholder
ASAAS_ENV=sandbox

# Transactional email
EMAIL_PROVIDER=none
EMAIL_FROM=atendimento@flipform.com.br
EMAIL_REPLY_TO=atendimento@flipform.com.br

# SMTP, used only if EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

# Resend, used only if EMAIL_PROVIDER=resend
RESEND_API_KEY=

# Internal jobs
CRON_SECRET=test-placeholder
INTERNAL_JOB_SECRET=test-placeholder

# Observability
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Production guard
ALLOW_EMAIL_PROVIDER_NONE_IN_PRODUCTION=false
ALLOW_SANDBOX_ASAAS_IN_PRODUCTION=false
