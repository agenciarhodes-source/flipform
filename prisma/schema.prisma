generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  owner
  admin
  manager
  agent
  viewer
}

enum TenantStatus {
  active
  trial
  past_due
  suspended
  blocked
  canceled
  // legacy: inactive — mantido para compat com dados antigos
  inactive
}

enum BillingCycle {
  monthly
  yearly
}

enum SubscriptionStatus {
  trialing
  active
  courtesy
  past_due
  suspended
  canceled
  unpaid
  paused
}

enum PaymentStatus {
  pending
  confirmed
  received
  overdue
  refunded
  failed
}

enum LeadStatus {
  open
  won
  lost
}

enum LeadTemperature {
  cold
  warm
  hot
}

enum TaskStatus {
  pending
  completed
  overdue
}

enum TaskPriority {
  low
  medium
  high
}

model Tenant {
  id            String       @id @default(uuid())
  name          String
  slug          String       @unique
  logoUrl       String?      @map("logo_url")
  primaryColor  String       @default("#2563EB") @map("primary_color")
  status        TenantStatus @default(active)
  planId        String?      @map("plan_id")
  nextDueDate   DateTime?    @map("next_due_date")
  internalNotes String?      @map("internal_notes")
  lastLoginAt   DateTime?    @map("last_login_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  tenantUsers           TenantUser[]
  forms                 Form[]
  pipelines             Pipeline[]
  leads                 Lead[]
  notes                 Note[]
  tasks                 Task[]
  auditLogs             AuditLog[]
  invites               Invite[]
  allowedUsers          AllowedUser[]
  plan                  Plan?                      @relation(fields: [planId], references: [id])
  subscriptions         Subscription[]
  payments              Payment[]
  statusHistory         TenantStatusHistory[]
  webhookEvents         WebhookEvent[]
  firstAccessTokens     FirstAccessToken[]
  integrationSettings   TenantIntegrationSettings?
  trackingEventMappings KanbanStageTrackingEvent[]
  trackingEventLogs     TrackingEventLog[]
  whatsappEventTriggers WhatsAppEventTrigger[]

  @@map("tenants")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  avatarUrl    String?  @map("avatar_url")
  globalRole   String?  @map("global_role") // null | "platform_admin"
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenantUsers         TenantUser[]
  assignedLeads       Lead[]                @relation("AssignedLeads")
  stageChanges        LeadStageHistory[]    @relation("StageChanger")
  notes               Note[]
  assignedTasks       Task[]                @relation("AssignedTasks")
  createdTasks        Task[]                @relation("CreatedTasks")
  auditLogs           AuditLog[]
  invitesIssued       Invite[]              @relation("InviteIssuer")
  tenantStatusChanges TenantStatusHistory[] @relation("StatusChanger")
  allowedInvites      AllowedUser[]         @relation("AllowedUserInviter")

  @@map("users")
}

model TenantUser {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  role      Role     @default(agent)
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@map("tenant_users")
}

model Pipeline {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  name       String
  isDefault  Boolean  @default(false) @map("is_default")
  isArchived Boolean  @default(false) @map("is_archived")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stages PipelineStage[]
  forms  Form[]
  leads  Lead[]

  @@map("pipelines")
}

model PipelineStage {
  id         String   @id @default(uuid())
  pipelineId String   @map("pipeline_id")
  name       String
  color      String   @default("#3B82F6")
  orderIndex Int      @map("order_index")
  isArchived Boolean  @default(false) @map("is_archived")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  pipeline       Pipeline           @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  formsAsInitial Form[]
  leads          Lead[]
  fromHistory    LeadStageHistory[] @relation("FromStage")
  toHistory      LeadStageHistory[] @relation("ToStage")

  @@map("pipeline_stages")
}

model Form {
  id                String   @id @default(uuid())
  tenantId          String   @map("tenant_id")
  name              String
  publicTitle       String   @map("public_title")
  publicDescription String?  @map("public_description")
  slug              String   @unique
  primaryColor      String   @default("#2563EB") @map("primary_color")
  bgColor           String?  @map("bg_color")
  buttonColor       String?  @map("button_color")
  textColor         String?  @map("text_color")
  theme             String   @default("light") // light | dark
  logoUrl           String?  @map("logo_url")
  coverImageUrl     String?  @map("cover_image_url")
  successMessage    String   @default("Obrigado pelo envio!") @map("success_message")
  pipelineId        String   @map("pipeline_id")
  initialStageId    String   @map("initial_stage_id")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pipeline     Pipeline      @relation(fields: [pipelineId], references: [id])
  initialStage PipelineStage @relation(fields: [initialStageId], references: [id])
  fields       FormField[]
  leads        Lead[]

  @@index([tenantId, createdAt])
  @@index([tenantId, pipelineId])
  @@index([tenantId, isActive])
  @@map("forms")
}

model FormField {
  id              String   @id @default(uuid())
  formId          String   @map("form_id")
  label           String
  placeholder     String?
  description     String?
  fieldType       String   @map("field_type")
  options         Json?
  isRequired      Boolean  @default(false) @map("is_required")
  orderIndex      Int      @map("order_index")
  validationRules Json?    @map("validation_rules")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  form    Form         @relation(fields: [formId], references: [id], onDelete: Cascade)
  answers LeadAnswer[]

  @@map("form_fields")
}

model Lead {
  id          String          @id @default(uuid())
  tenantId    String          @map("tenant_id")
  formId      String?         @map("form_id")
  pipelineId  String          @map("pipeline_id")
  stageId     String          @map("stage_id")
  assignedTo  String?         @map("assigned_to")
  name        String
  email       String?
  phone       String?
  source      String          @default("formulario")
  status      LeadStatus      @default(open)
  temperature LeadTemperature @default(cold)
  lostReason  String?         @map("lost_reason")
  tags        String[]        @default([])
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  form         Form?              @relation(fields: [formId], references: [id], onDelete: SetNull)
  pipeline     Pipeline           @relation(fields: [pipelineId], references: [id])
  stage        PipelineStage      @relation(fields: [stageId], references: [id])
  assignedUser User?              @relation("AssignedLeads", fields: [assignedTo], references: [id])
  answers      LeadAnswer[]
  history      LeadStageHistory[]
  notes        Note[]
  tasks        Task[]

  @@index([tenantId])
  @@index([stageId])
  @@index([tenantId, pipelineId])
  @@index([tenantId, stageId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, assignedTo])
  @@map("leads")
}

model LeadAnswer {
  id            String   @id @default(uuid())
  leadId        String   @map("lead_id")
  fieldId       String?  @map("field_id")
  questionLabel String   @map("question_label")
  answer        Json
  createdAt     DateTime @default(now()) @map("created_at")

  lead  Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  field FormField? @relation(fields: [fieldId], references: [id], onDelete: SetNull)

  @@map("lead_answers")
}

model LeadStageHistory {
  id          String   @id @default(uuid())
  leadId      String   @map("lead_id")
  fromStageId String?  @map("from_stage_id")
  toStageId   String   @map("to_stage_id")
  changedBy   String?  @map("changed_by")
  createdAt   DateTime @default(now()) @map("created_at")

  lead      Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  fromStage PipelineStage? @relation("FromStage", fields: [fromStageId], references: [id])
  toStage   PipelineStage  @relation("ToStage", fields: [toStageId], references: [id])
  changer   User?          @relation("StageChanger", fields: [changedBy], references: [id])

  @@index([leadId, createdAt])
  @@index([toStageId, createdAt])
  @@map("lead_stage_history")
}

model Note {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  leadId    String   @map("lead_id")
  userId    String   @map("user_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@map("notes")
}

model Task {
  id          String       @id @default(uuid())
  tenantId    String       @map("tenant_id")
  leadId      String?      @map("lead_id")
  assignedTo  String?      @map("assigned_to")
  createdBy   String?      @map("created_by")
  title       String
  description String?
  dueDate     DateTime?    @map("due_date")
  priority    TaskPriority @default(medium)
  status      TaskStatus   @default(pending)
  completedAt DateTime?    @map("completed_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead     Lead?  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignee User?  @relation("AssignedTasks", fields: [assignedTo], references: [id])
  creator  User?  @relation("CreatedTasks", fields: [createdBy], references: [id])

  @@index([tenantId])
  @@index([leadId])
  @@index([assignedTo])
  @@index([dueDate])
  @@index([tenantId, assignedTo])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("tasks")
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  userId     String?  @map("user_id")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  action     String
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

model Invite {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  email      String
  role       Role      @default(agent)
  token      String    @unique
  invitedBy  String?   @map("invited_by")
  status     String    @default("pending") // pending | accepted | revoked | expired
  expiresAt  DateTime  @map("expires_at")
  acceptedAt DateTime? @map("accepted_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inviter User?  @relation("InviteIssuer", fields: [invitedBy], references: [id])

  @@index([tenantId])
  @@index([email])
  @@map("invites")
}

model AllowedUser {
  id         String    @id @default(cuid())
  email      String
  tenantId   String    @map("tenant_id")
  role       String
  active     Boolean   @default(true)
  status     String    @default("active")
  source     String    @default("admin")
  invitedBy  String?   @map("invited_by")
  acceptedAt DateTime? @map("accepted_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inviter User?  @relation("AllowedUserInviter", fields: [invitedBy], references: [id])

  @@unique([tenantId, email], name: "tenantId_email")
  @@index([email])
  @@index([tenantId])
  @@index([active])
  @@map("allowed_users")
}

model EmailVerificationCode {
  id          String    @id @default(cuid())
  email       String
  codeHash    String    @map("code_hash")
  purpose     String
  attempts    Int       @default(0)
  maxAttempts Int       @default(5) @map("max_attempts")
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([email, purpose])
  @@index([expiresAt])
  @@map("email_verification_codes")
}

// ============================================================================
// Fase 8 — Billing / Plataforma (preparação para Asaas; sem integração real)
// ============================================================================

model Plan {
  id                   String       @id @default(uuid())
  name                 String
  description          String?
  price                Decimal      @db.Decimal(10, 2)
  billingCycle         BillingCycle @default(monthly) @map("billing_cycle")
  maxUsers             Int          @default(0) @map("max_users")
  maxForms             Int          @default(0) @map("max_forms")
  slug                 String       @unique
  maxLeadsPerMonth     Int          @default(0) @map("max_leads_per_month")
  maxPipelines         Int          @default(0) @map("max_pipelines")
  canUseReports        Boolean      @default(false) @map("can_use_reports")
  canExportCsv         Boolean      @default(false) @map("can_export_csv")
  canUseCustomBranding Boolean      @default(false) @map("can_use_custom_branding")
  canUseMetaPixel      Boolean      @default(false) @map("can_use_meta_pixel")
  canUseWebhooks       Boolean      @default(false) @map("can_use_webhooks")
  canUseTasks          Boolean      @default(true) @map("can_use_tasks")
  isActive             Boolean      @default(true) @map("is_active")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  tenants       Tenant[]
  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                     String             @id @default(uuid())
  tenantId               String             @map("tenant_id")
  planId                 String             @map("plan_id")
  status                 SubscriptionStatus @default(trialing)
  currentPeriodStart     DateTime?          @map("current_period_start")
  currentPeriodEnd       DateTime?          @map("current_period_end")
  nextDueDate            DateTime?          @map("next_due_date")
  provider               String             @default("asaas")
  paymentRequired        Boolean            @default(true) @map("payment_required")
  gracePeriodEndsAt      DateTime?          @map("grace_period_ends_at")
  paymentProvider        String?            @default("asaas") @map("payment_provider")
  providerCustomerId     String?            @map("provider_customer_id")
  providerSubscriptionId String?            @map("provider_subscription_id")
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")
  canceledAt             DateTime?          @map("canceled_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan     Plan      @relation(fields: [planId], references: [id])
  payments Payment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, nextDueDate])
  @@map("subscriptions")
}

model Payment {
  id                String        @id @default(uuid())
  tenantId          String        @map("tenant_id")
  subscriptionId    String?       @map("subscription_id")
  provider          String        @default("asaas")
  providerPaymentId String?       @map("provider_payment_id")
  status            PaymentStatus @default(pending)
  value             Decimal       @db.Decimal(10, 2)
  dueDate           DateTime?     @map("due_date")
  paidAt            DateTime?     @map("paid_at")
  invoiceUrl        String?       @map("invoice_url")
  bankSlipUrl       String?       @map("bank_slip_url")
  pixQrCode         String?       @map("pix_qr_code")
  billingType       String?       @map("billing_type")
  rawPayload        Json?         @map("raw_payload")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@index([tenantId, createdAt])
  @@map("payments")
}

model FirstAccessToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique @map("token_hash")
  email     String
  tenantId  String    @map("tenant_id")
  purpose   String
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([email, tenantId])
  @@index([tenantId, expiresAt])
  @@map("first_access_tokens")
}

model WebhookEvent {
  id                String    @id @default(cuid())
  provider          String
  eventId           String    @map("event_id")
  eventType         String    @map("event_type")
  providerPaymentId String?   @map("provider_payment_id")
  rawPayload        Json?     @map("raw_payload")
  processedAt       DateTime? @map("processed_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  tenantId          String?   @map("tenant_id")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@unique([provider, eventId])
  @@index([providerPaymentId])
  @@map("webhook_events")
}

model TenantStatusHistory {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  previousStatus String?  @map("previous_status")
  newStatus      String   @map("new_status")
  reason         String?
  changedBy      String?  @map("changed_by")
  createdAt      DateTime @default(now()) @map("created_at")

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  changer User?  @relation("StatusChanger", fields: [changedBy], references: [id])

  @@index([tenantId, createdAt])
  @@map("tenant_status_history")
}

model TenantIntegrationSettings {
  id                       String   @id @default(cuid())
  tenantId                 String   @unique @map("tenant_id")
  metaPixelEnabled         Boolean  @default(false) @map("meta_pixel_enabled")
  metaPixelId              String?  @map("meta_pixel_id")
  metaAccessTokenEncrypted String?  @map("meta_access_token_encrypted")
  metaTestEventCode        String?  @map("meta_test_event_code")
  gtmEnabled               Boolean  @default(false) @map("gtm_enabled")
  gtmContainerId           String?  @map("gtm_container_id")
  ga4Enabled               Boolean  @default(false) @map("ga4_enabled")
  ga4MeasurementId         String?  @map("ga4_measurement_id")
  ga4ApiSecretEncrypted    String?  @map("ga4_api_secret_encrypted")
  googleAdsEnabled         Boolean  @default(false) @map("google_ads_enabled")
  googleAdsId              String?  @map("google_ads_id")
  googleAdsLabel           String?  @map("google_ads_label")
  whatsappFunnelEnabled    Boolean  @default(false) @map("whatsapp_funnel_enabled")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_integration_settings")
}

model KanbanStageTrackingEvent {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  pipelineId      String?  @map("pipeline_id")
  stageId         String   @map("stage_id")
  provider        String
  eventName       String   @map("event_name")
  customEventName String?  @map("custom_event_name")
  conversionLabel String?  @map("conversion_label")
  conversionValue Decimal? @map("conversion_value") @db.Decimal(10, 2)
  currency        String   @default("BRL")
  metadata        Json?
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([stageId])
  @@index([tenantId, stageId, provider])
  @@map("kanban_stage_tracking_events")
}

model WhatsAppEventTrigger {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  name            String
  orderIndex      Int      @default(0) @map("order_index")
  triggerPhrase   String   @map("trigger_phrase")
  matchType       String   @default("exact") @map("match_type")
  provider        String   @default("meta")
  eventName       String   @map("event_name")
  customEventName String?  @map("custom_event_name")
  conversionValue Decimal? @map("conversion_value") @db.Decimal(10, 2)
  currency        String   @default("BRL")
  pipelineId      String?  @map("pipeline_id")
  stageId         String?  @map("stage_id")
  oncePerLead     Boolean  @default(true) @map("once_per_lead")
  requireExactMatch Boolean @default(true) @map("require_exact_match")
  enabled         Boolean  @default(true)
  lastTriggeredAt DateTime? @map("last_triggered_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, triggerPhrase, matchType], name: "whatsapp_event_triggers_tenant_phrase_match_key")
  @@index([tenantId])
  @@index([tenantId, enabled, orderIndex])
  @@index([pipelineId])
  @@index([stageId])
  @@map("whatsapp_event_triggers")
}

model TrackingEventLog {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  leadId        String?  @map("lead_id")
  pipelineId    String?  @map("pipeline_id")
  fromStageId   String?  @map("from_stage_id")
  toStageId     String?  @map("to_stage_id")
  provider      String
  eventName     String   @map("event_name")
  status        String
  reason        String?
  triggeredById String?  @map("triggered_by_id")
  eventId       String?  @map("event_id")
  conversationId String? @map("conversation_id")
  messageId     String? @map("message_id")
  triggerRuleId String? @map("trigger_rule_id")
  messageDirection String? @map("message_direction")
  source        String?
  createdAt     DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([leadId])
  @@index([createdAt])
  @@index([tenantId, provider, createdAt])
  @@index([tenantId, triggerRuleId, eventName])
  @@index([tenantId, conversationId])
  @@map("tracking_event_logs")
}
